{
  "version": 3,
  "configurePresets": [
    {
      "name": "vcpkg-ninja",
      "displayName": "Vcpkg + Ninja",
      "description": "Uses Ninja generator with vcpkg toolchain",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
      }
    }
  ]
}